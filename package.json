{
  "name": "rig",
  "version": "0.2.6",
  "description": "Agent harness that enforces tool routing, skill chains, and multi-agent discipline in Claude Code",
  "type": "module",
  "main": "dist/cli/index.js",
  "exports": {
    "./*": "./dist/*"
  },
  "bin": {
    "rig": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "lint:md": "markdownlint-cli2 '**/*.md'"
  },
  "keywords": [
    "claude-code",
    "agent-harness",
    "guardrails"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "markdownlint-cli2": "^0.22.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "yaml": "^2.7.0"
  }
}
